# ==================== SERVICE PORTS ====================
GATEWAY_PORT=8080
CORE_SERVICE_PORT=8081
CHAT_SERVICE_PORT=3001
AI_SERVICE_PORT=8000

# ==================== MONGODB ====================
MONGO_HOST=platform-mongodb
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=admin123
MONGO_DATABASE=eduplatform
MONGO_URL=mongodb://admin:admin123@platform-mongodb:27017/eduplatform?authSource=admin

# ==================== REDIS ====================
REDIS_HOST=platform-redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@platform-redis:6379

# ==================== RABBITMQ ====================
RABBITMQ_HOST=platform-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://admin:admin123@platform-rabbitmq:5672/

# ==================== CONSUL ====================
CONSUL_HOST=platform-consul
CONSUL_PORT=8500

# ==================== CHROMADB ====================
CHROMADB_HOST=platform-chromadb
CHROMADB_PORT=8000

# ==================== JWT SECRETS ====================
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRY_MINUTES=30
JWT_REFRESH_EXPIRY_DAYS=7

# ==================== ENVIRONMENT ====================
SPRING_PROFILES_ACTIVE=local
ENVIRONMENT=development

# ==================== EMAIL ====================
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yourgmail@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=yourgmail@gmail.com
SMTP_FROM_NAME=EduPlatform
SMTP_STARTTLS_ENABLE=true
SMTP_SSL_ENABLE=false
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@eduplatform.com
RESEND_FROM_NAME=EduPlatform
FRONTEND_RESET_URL=http://localhost:8084/reset-password
PASSWORD_RESET_EXPIRY_MINUTES=30

# ==================== SMS OTP (TWILIO) ====================
TWILIO_ACCOUNT_SID=ACxxxxxx
TWILIO_AUTH_TOKEN=xxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ==================== PAYMENTS (RAZORPAY) ====================
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxx

# ==================== LLM MODELS ====================
# Change to: ollama/llama3 (free, local) or groq/llama3-70b-8192 (free cloud)
MODEL_NAME=ollama/llama3
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ==================== GROQ API (optional) ====================
GROQ_API_KEY=gsk_xxxxx

# ==================== OPENAI (optional) ====================
OPENAI_API_KEY=sk_xxxxx
